# Exceptions to exclusions (must be at the bottom so they are not overridden by general wildcards above)
!media/uploads/.gitkeep
!media/uploads/cricket_full_match.mp4
!backend/static/demo/demo-video.mp4
!backend/static/demo/demo.mp4

# OS related
.DS_Store
Thumbs.db

