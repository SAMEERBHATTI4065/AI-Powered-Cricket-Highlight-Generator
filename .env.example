# ============================================================
# Environment Configuration - AI Cricket Highlight Generator
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual API keys below
#   3. NEVER commit the .env file to Git (it is in .gitignore)
# ============================================================

# ----- Storage Paths -----
# Path on your HOST machine where video data will be stored
# Windows: use forward slashes (e.g., E:/Cricket_Data)
# Linux/Mac: use normal path (e.g., /home/user/cricket_data)
HOST_DATA_ROOT=E:/Cricket_Data

MEDIA_ROOT=media
TEMP_ROOT=temp
EVENT_ANALYSIS_ROOT=event_analysis
LOGS_ROOT=logs

# ----- Google Cloud Vision API -----
# Download your service account JSON key from Google Cloud Console
# Place the JSON file in the project root and enter the filename below
# Guide: https://cloud.google.com/vision/docs/setup
GOOGLE_APPLICATION_CREDENTIALS=your-google-credentials.json

# ----- OpenAI API -----
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ----- Django Settings -----
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=1

# ----- Database (auto-configured for Docker) -----
DATABASE_URL=postgresql://postgres:postgres@db:5432/cricket_highlights

# ----- Redis (auto-configured for Docker) -----
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
